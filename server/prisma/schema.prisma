generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  passwordHash  String     @map("password_hash")
  role          String     @default("customer")
  totalOrders   Int        @default(0) @map("total_orders")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  orders    Order[]
  cartItems CartItem[]
  addresses Address[]
  @@map("users")
}

model Product {
  id           String   @id @default(uuid())
  name         String
  description  String
  imageUrl     String   @map("image_url")
  category     String
  basePrice    Float    @map("base_price")
  floorPrice   Float    @map("floor_price")
  ceilingPrice Float    @map("ceiling_price")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  inventory        Inventory?
  demandTracker    DemandTracker?
  priceHistory     PriceHistory[]
  competitorPrices CompetitorPrice[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  @@map("products")
}

model Inventory {
  id                String   @id @default(uuid())
  productId         String   @unique @map("product_id")
  quantity          Int
  lowStockThreshold Int      @default(10) @map("low_stock_threshold")
  updatedAt         DateTime @updatedAt @map("updated_at")
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("inventory")
}

model DemandTracker {
  id               String   @id @default(uuid())
  productId        String   @unique @map("product_id")
  viewCount1h      Int      @default(0) @map("view_count_1h")
  viewCount24h     Int      @default(0) @map("view_count_24h")
  purchaseCount1h  Int      @default(0) @map("purchase_count_1h")
  purchaseCount24h Int      @default(0) @map("purchase_count_24h")
  lastResetAt      DateTime @default(now()) @map("last_reset_at")
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("demand_tracker")
}

model PriceHistory {
  id               String   @id @default(uuid())
  productId        String   @map("product_id")
  price            Float
  basePrice        Float    @map("base_price")
  demandFactor     Float    @map("demand_factor")
  stockFactor      Float    @map("stock_factor")
  timeFactor       Float    @map("time_factor")
  competitorFactor Float    @map("competitor_factor")
  loyaltyDiscount  Float    @map("loyalty_discount")
  recordedAt       DateTime @default(now()) @map("recorded_at")
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("price_history")
}

model CompetitorPrice {
  id             String   @id @default(uuid())
  productId      String   @map("product_id")
  competitorName String   @map("competitor_name")
  price          Float
  lastChecked    DateTime @default(now()) @map("last_checked")
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("competitor_prices")
}

model Order {
  id                String      @id @default(uuid())
  userId            String      @map("user_id")
  totalAmount       Float       @map("total_amount")
  status            String      @default("pending")
  razorpayOrderId   String?     @map("razorpay_order_id")
  razorpayPaymentId String?     @map("razorpay_payment_id")
  deliveryAddressId String?     @map("delivery_address_id")
  deliveryDate      DateTime?   @map("delivery_date")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  user              User        @relation(fields: [userId], references: [id])
  address           Address?    @relation(fields: [deliveryAddressId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  @@map("orders")
}

model Address {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @default("home")
  street    String
  city      String
  state     String
  zipCode   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
  @@map("addresses")
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String  @map("order_id")
  productId       String  @map("product_id")
  quantity        Int
  priceAtPurchase Float   @map("price_at_purchase")
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  @@map("order_items")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  addedAt   DateTime @default(now()) @map("added_at")
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@unique([userId, productId])
  @@map("cart_items")
}
